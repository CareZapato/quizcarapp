{
  "name": "test-conduccion-web",
  "version": "0.4.3",
  "description": "Plataforma web para cuestionarios de conducción teóricos",
  "main": "server/index.js",
  "type": "module",
  "scripts": {
    "start": "node server/index.js",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "dev:clean": "concurrently \"set NODE_OPTIONS=--no-deprecation && npm run server\" \"start-client.bat\"",
    "server": "nodemon server/index.js",
    "client": "cd client && npm start",
    "build": "cd client && npm run build",
    "install-all": "npm install && cd client && npm install",
    "setup": "npm run install-all && npm run init-db",
    "init-db": "node server/scripts/initDatabase.js",
    "migrate": "node server/scripts/migrate-multiple-answers.js"
  },
  "keywords": [
    "driving",
    "test",
    "quiz",
    "education"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.16.3",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "nodemon": "^3.0.2"
  }
}
