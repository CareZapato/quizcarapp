# ==============================================
# CONFIGURACIÓN DEL CLIENTE (React)
# Copiar este archivo como .env y ajustar según
# necesites. Los scripts start-*.bat/sh lo
# generan automáticamente.
# ==============================================

# Puerto del servidor de desarrollo React
PORT=3001

# No abrir navegador automáticamente
BROWER=none

# Puerto del backend (desarrollo local y en red)
# La app construye la URL de la API en runtime:
#   http://<mismo hostname que el front>:<REACT_APP_API_PORT>/api
# Funciona en localhost y en cualquier IP sin configurar nada más.
REACT_APP_API_PORT=3000

# URL absoluta del backend (producción — Render, VPS, etc.)
# Si se define, tiene prioridad sobre REACT_APP_API_PORT.
# Úsalo cuando front y backend están en dominios distintos.
# REACT_APP_API_URL=https://mi-api.onrender.com/api

# Deshabilitar source maps en producción (reduce tamaño)
GENERATE_SOURCEMAP=false
