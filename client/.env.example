# ==============================================
# CONFIGURACIÓN DEL CLIENTE (React)
# Copiar este archivo como .env y ajustar según
# necesites. Los scripts start-*.bat/sh lo
# generan automáticamente.
# ==============================================

# Puerto del servidor de desarrollo React
PORT=3001

# No abrir navegador automáticamente
BROWER=none

# Puerto del backend
# La app construye la URL de la API en tiempo de ejecución (runtime):
#   http://<mismo hostname que el front>:<REACT_APP_API_PORT>/api
# Así funciona en local (localhost) y en red (cualquier IP)
# sin necesidad de configurar IPs manualmente.
REACT_APP_API_PORT=3000

# Deshabilitar source maps en producción (reduce tamaño)
GENERATE_SOURCEMAP=false
