# Puerto del servidor de desarrollo React
PORT=3001

# No abrir navegador automáticamente
BROWSER=none

# URL de la API del servidor
# Para desarrollo local (mismo dispositivo):
#   REACT_APP_API_URL=http://localhost:3000/api
#
# Para acceso por red (desde otros dispositivos):
#   REACT_APP_API_URL=http://TU_IP:3000/api
#   Ejemplo: REACT_APP_API_URL=http://192.168.1.200:3000/api
#
# Nota: Debes obtener tu IP local con:
#   Windows: ipconfig
#   Linux/Mac: ifconfig o ip addr

REACT_APP_API_URL=http://localhost:3000/api
